# Use official Node.js image as base
FROM node:20-alpine

# Set working directory inside the container
WORKDIR /app

# Copy all project files into the container
COPY . .

# Install root dependencies AND backend-specific dependencies
RUN npm install --legacy-peer-deps
RUN npm install --prefix stellar-payment-platform --legacy-peer-deps

# Expose the backend port (update if your app uses a different port)
EXPOSE 5000

# Start the application from the backend directory
CMD ["npm", "--prefix", "stellar-payment-platform", "start"]